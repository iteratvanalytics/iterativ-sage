# ─────────────────────────────────────────────────────────────────────────────
# Sage environment variables
#
# Copy this file to `.env` and fill in the values. With NONE of these set, the
# app runs in demo mode: an in-memory data store backs all queries and the local
# mock agent generates replies, so the full UI works with no backend.
# ─────────────────────────────────────────────────────────────────────────────

# --- Supabase (enables real persistence + multi-user auth) ---------------------
# Client-side (exposed to the browser). Safe to ship — protected by RLS.
VITE_SUPABASE_URL=
VITE_SUPABASE_PUBLISHABLE_KEY=

# Server-side only (NEVER expose to the client). Used by server functions/routes.
SUPABASE_URL=
SUPABASE_PUBLISHABLE_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# --- Anthropic (enables real AI replies instead of the mock agent) -------------
# When unset, chat falls back to the rich local mock agent.
ANTHROPIC_API_KEY=
# Optional: override the model used for chat replies.
ANTHROPIC_MODEL=claude-sonnet-4-6
